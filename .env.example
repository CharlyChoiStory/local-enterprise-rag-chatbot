# ─────────────────────────────────────────────────────────
# Local RAG Chatbot – 환경 설정 예시
# 이 파일을 복사해 .env로 저장한 뒤 값을 맞게 수정하세요.
# 외부 AI API key 항목은 없습니다 (보안 정책 준수).
# ─────────────────────────────────────────────────────────

# Ollama 서버 주소 (기본값: 로컬)
OLLAMA_BASE_URL=http://localhost:11434

# 채팅에 사용할 로컬 LLM 모델
# 권장: llama3.1:8b | qwen2.5:7b
OLLAMA_CHAT_MODEL=llama3.1:8b

# 임베딩에 사용할 로컬 모델
# 권장: bge-m3 | nomic-embed-text
OLLAMA_EMBEDDING_MODEL=bge-m3

# 문서 폴더 경로 (기본값: 프로젝트 루트 기준 상대경로)
SOURCE_DOCS_DIR=data/source_docs

# Chroma 저장 경로
CHROMA_PERSIST_DIR=data/chroma

# Chroma 컬렉션 이름
CHROMA_COLLECTION_NAME=company_documents

# 검색 결과 상위 k개
TOP_K=5

# Chunk 크기 (글자 수)
CHUNK_SIZE=1600

# Chunk overlap 크기 (글자 수)
CHUNK_OVERLAP=250
